<launch>
    <node pkg="speech_recognition"
          type="llm_command_classifier.py"
          name="llm_command_classifier"
          output="screen">

        <param name="input_topic" value="/voice/text" />

        <param name="command_topic" value="/voice/command" />
        <param name="json_topic" value="/voice/command_json" />

        <param name="ollama_base_url" value="http://127.0.0.1:11434/v1" />
        <param name="model" value="llama3.1:8b" />

        <param name="temperature" value="0.0" />
        <param name="max_tokens" value="80" />
        <param name="timeout" value="30.0" />

        <param name="publish_unknown_on_error" value="true" />
    </node>
</launch>