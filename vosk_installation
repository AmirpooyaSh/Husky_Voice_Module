sudo apt update
sudo apt install -y curl gnupg2 lsb-release

sudo sh -c 'echo "deb http://packages.ros.org/ros/ubuntu $(lsb_release -sc) main" > /etc/apt/sources.list.d/ros-latest.list'

curl -s https://raw.githubusercontent.com/ros/rosdistro/master/ros.asc | sudo apt-key add -

sudo apt update
sudo apt install -y ros-melodic-ros-base

sudo apt install -y \
  python-rosdep \
  python-rosinstall \
  python-rosinstall-generator \
  python-wstool \
  python-catkin-tools \
  build-essential

sudo rosdep init 2>/dev/null || true
rosdep update

echo "source /opt/ros/melodic/setup.bash" >> ~/.bashrc
source ~/.bashrc

sudo apt update
sudo apt install -y \
  python3-pip \
  python3-dev \
  portaudio19-dev \
  libasound2-dev \
  unzip \
  wget

python3 -m pip install --user --upgrade pip setuptools wheel
python3 -m pip install --user vosk sounddevice numpy rospkg

python3 - <<'PY'
import vosk
import sounddevice
import numpy
print("vosk ok")
print("sounddevice ok")
PY

python3 - <<'PY'
import sounddevice as sd
print(sd.query_devices())
PY

cd src/speech_recognition/models
wget -nc https://alphacephei.com/vosk/models/vosk-model-small-en-us-0.15.zip

unzip -n vosk-model-small-en-us-0.15.zip

rosdep install --from-paths src --ignore-src -r -y --rosdistro melodic

catkin_make

grep -qxF "source ~/Husky_Voice_Module/devel/setup.bash" ~/.bashrc || \
echo "source ~/Husky_Voice_Module/devel/setup.bash" >> ~/.bashrc


